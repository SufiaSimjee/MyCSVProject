<!DOCTYPE html>
<html>
<head>
  <title>CSV Tables</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

<div class="container py-4">

  <h2 class="mb-4 text-center">CSV Table Viewer</h2>

  <!-- Upload Form -->
  <form action="/upload" method="POST" enctype="multipart/form-data" class="mb-4 text-center">
    <input type="file" name="csvfile" class="form-control w-50 mx-auto mb-2">
    <button class="btn btn-primary">Upload CSV</button>
  </form>

  <!-- TABLE 1 -->
  <h3>Table 1</h3>

  <div class="table-responsive mb-5">
    <table class="table table-bordered table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <% Object.keys(table1[0]).forEach(key => { %>
            <th><%= key %></th>
          <% }) %>
        </tr>
      </thead>

      <tbody>
        <% table1.forEach(row => { %>
          <tr>
            <% Object.values(row).forEach(val => { %>
              <td><%= val %></td>
            <% }) %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- TABLE 2 -->
  <h3>Table 2</h3>

  <div class="table-responsive">
    <table class="table table-bordered table-striped">
      <thead class="table-dark">
        <tr>
          <th>Category</th>
          <th>Value</th>
        </tr>
      </thead>

      <tbody>
        <% table2.forEach(row => { %>
          <tr>
            <td><%= row.category %></td>
            <td><%= row.value %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</div>

</body>
</html>